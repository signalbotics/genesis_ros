#!/usr/bin/make -f
# Vendored-venv build: we do NOT use dh_python3 because we ship a
# self-contained /opt/genesis/venv instead of installing into the system
# Python site-packages.

export DH_VERBOSE = 1

PREFIX      := /opt/genesis
VENV        := $(CURDIR)/debian/genesis-world$(PREFIX)/venv
# GENESIS_SRC must be set in the environment by packaging/build-all.sh and
# must point at the Genesis engine source tree (pyproject.toml + genesis/).
# We stage a writable copy under SRC_STAGE because pip/setuptools needs to
# create genesis_world.egg-info/ during build, which would fail on a
# read-only bind mount or clutter the user's upstream checkout.
REPO_ROOT   := $(GENESIS_SRC)
SRC_STAGE   := $(CURDIR)/debian/.genesis-src

%:
	dh $@

override_dh_auto_configure:
override_dh_auto_build:
override_dh_auto_test:

override_dh_auto_install:
	# Create the vendored venv using Python 3.12 (Noble's default).
	# We do NOT bundle the stdlib — rely on the system libpython3.12-stdlib
	# package (declared in Depends) so the venv's interpreter can find it.
	python3.12 -m venv --copies $(VENV)
	$(VENV)/bin/pip install --upgrade pip wheel setuptools
	# Pin numpy < 2 BEFORE any C-extension wheel lands. ROS 2 Jazzy ships
	# cv_bridge, tf_transformations and friends compiled against the
	# numpy 1.x ABI; a numpy 2.x in the venv gets prepended onto the
	# system python's sys.path by our .pth file (see below) and those
	# system .so files bomb with "compiled using NumPy 1.x cannot be run
	# in NumPy 2.x". Torch and Genesis both work fine on numpy < 2.
	$(VENV)/bin/pip install "numpy<2"
	# Write a pip constraints file honoured by every subsequent install
	# in this recipe, so torch / genesis deps cannot silently upgrade
	# numpy past the 1.x ABI cv_bridge expects.
	echo "numpy<2" > $(CURDIR)/debian/.pip-constraints.txt
	# Torch is intentionally not declared by genesis-world's pyproject.toml
	# (see upstream README — it's CUDA-version specific). Install it first so
	# `import torch` works out of the box. Default PyPI wheel ships with CUDA
	# 13 runtime; works on NVIDIA driver >= 550.
	$(VENV)/bin/pip install -c $(CURDIR)/debian/.pip-constraints.txt torch
	# Stage Genesis source into a writable dir (setuptools wants to create
	# egg-info during build; the upstream checkout may be read-only).
	rm -rf $(SRC_STAGE)
	mkdir -p $(SRC_STAGE)
	cp -a $(REPO_ROOT)/. $(SRC_STAGE)/
	# Install genesis-world from the staged copy.
	$(VENV)/bin/pip install -c $(CURDIR)/debian/.pip-constraints.txt $(SRC_STAGE)
	rm -rf $(SRC_STAGE)
	# RL training stack used by go2_train / hover_train / grasp_train console
	# scripts. Bundled so `ros2 run genesis_ros *_train` works out of the box.
	# rsl-rl-lib supports three logger backends (tensorboard / wandb / neptune)
	# but declares none as hard deps -- ship all three. tensordict is needed
	# by the *_env.py observation containers.
	$(VENV)/bin/pip install -c $(CURDIR)/debian/.pip-constraints.txt \
		"rsl-rl-lib>=5.0.0" \
		tensordict \
		tensorboard \
		wandb \
		neptune-client
	rm -f $(CURDIR)/debian/.pip-constraints.txt
	# Strip the absolute build path out of the venv so it runs from /opt/genesis.
	$(VENV)/bin/python -c "import subprocess,sys; subprocess.check_call([sys.executable, '-m', 'pip', 'check'])" || true
	# Rewrite shebangs from the build dir to /opt/genesis/venv.
	grep -rlI "$(VENV)" $(VENV)/bin 2>/dev/null | xargs -r sed -i "s|$(VENV)|$(PREFIX)/venv|g"
	# Wrapper + desktop wiring.
	install -Dm755 $(CURDIR)/wrapper/genesis \
	    $(CURDIR)/debian/genesis-world/usr/bin/genesis
	# Expose the vendored venv's site-packages to the system Python so
	# packages like genesis_ros (installed into ROS's site-packages under
	# /opt/ros/jazzy/...) can `import genesis`. Requires the system python3
	# to be 3.12 (enforced via Depends: python3.12).
	install -d $(CURDIR)/debian/genesis-world/usr/lib/python3/dist-packages
	# Use the site-module `import` form so the venv path is PREPENDED to
	# sys.path; otherwise the system _cffi_backend shadows the venv's, and
	# similar C-extension clashes trigger "Version mismatch" errors.
	echo "import sys; sys.path.insert(0, '/opt/genesis/venv/lib/python3.12/site-packages')" > \
	    $(CURDIR)/debian/genesis-world/usr/lib/python3/dist-packages/genesis-venv.pth

override_dh_shlibdeps:
	# The venv bundles torch/taichi .so files we can't resolve against system
	# libs — skip shlibdeps for the venv tree.
	dh_shlibdeps -Xgenesis/venv

override_dh_strip:
	dh_strip -Xgenesis/venv

override_dh_dwz:
	# Wheel .so files have stripped/odd debug sections; skip dwz for the venv.
	dh_dwz -Xgenesis/venv

override_dh_fixperms:
	dh_fixperms -Xgenesis/venv/bin
